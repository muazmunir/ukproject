APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

SESSION_SAME_SITE=lax

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

ASSET_VERSION=20260111_1

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

WEBAUTHN_NAME="ZAIVIAS"
WEBAUTHN_ID=example.com
WEBAUTHN_ORIGINS=https://example.com

DB_CONNECTION=mysql
# Use 127.0.0.1 (not "localhost") on shared hosting if mysql CLI gets Access denied for user@::1
DB_HOST=127.0.0.1
DB_PORT=3306
# DB_SOCKET=/path/to/mysql.sock

# Replace u123456789 everywhere below with your Hostinger MySQL prefix (same as in hPanel database names).
# Local (Laragon etc.): set DB_USERNAME=root, DB_DATABASE (monolith / split source) and DB_DATABASE_MULTI_ENTRY plus domain DB_* names (can all point at one schema for a simple dev box).
DB_DATABASE=u123456789_zaivias
DB_USERNAME=u123456789_admin
# Used for every split connection when DB_AUTH_PASSWORD, DB_PII_PASSWORD, … are empty or omitted.
DB_PASSWORD=

# Optional: monolith for split command if it differs from DB_DATABASE
# DB_SPLIT_SOURCE=u123456789_zaivias

# Empty metadata DB (create in hPanel before php artisan db:split-multi). If omitted and DB_AUTH_DATABASE ends with _auth_db, name is inferred.
DB_SPLIT_CONTROL_DATABASE=u123456789_split_control
# If hPanel created user = database name (u123…_split_control), leave username unset: config uses the schema name.
# Empty DB_SPLIT_CONTROL_PASSWORD falls back to DB_PASSWORD above.
# DB_SPLIT_CONTROL_USERNAME=u123456789_split_control
# DB_SPLIT_CONTROL_PASSWORD=

# Optional: mysql user that pipes split-databases.sql (defaults to split_control connection). Often the per-DB metadata user.
# DB_SPLIT_CLI_USERNAME=u123456789_split_control
# DB_SPLIT_CLI_PASSWORD=

# User that runs CALL copy_mapped_tables() — must SELECT monolith + INSERT into all domain DBs. Defaults to DB_USERNAME / DB_PASSWORD.
# DB_SPLIT_CALL_USERNAME=u123456789_admin
# DB_SPLIT_CALL_PASSWORD=

# Hostinger (one MySQL user per database): set true or use php artisan db:split-multi --force --php-copy
# DB_SPLIT_USE_PHP_COPY=false

# Alternative: mysqldump per table → storage/app/db-split-export/{auth_db|pii_db|…}/ then import each with that DB’s user:
# php artisan db:split-multi:export --force
# php artisan db:split-multi:import --force

# Default mysql connection uses the same user/password as the entry DB (DB_DATABASE_MULTI_ENTRY, usually auth_db) when that schema matches a row below, so Hostinger per-DB users work.
DB_DATABASE_MULTI_ENTRY=u123456789_auth_db
DB_AUTH_DATABASE=u123456789_auth_db
DB_PII_DATABASE=u123456789_pii_db
DB_KYC_DATABASE=u123456789_kyc_db
DB_PAYMENTS_DATABASE=u123456789_payments_db
DB_APP_DATABASE=u123456789_app_db
DB_COMMS_DATABASE=u123456789_comms_db
DB_MEDIA_DATABASE=u123456789_media_db
DB_AUDIT_DATABASE=u123456789_audit_db

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_DESCRIPTOR_SUFFIX=ZAIVIAS

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

JAAS_APP_ID=
JAAS_KID=
JAAS_PRIVATE_KEY=
JAAS_DOMAIN=8x8.vc

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
